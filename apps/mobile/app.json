{
  "expo": {
    "name": "Balkina AI",
    "slug": "balkina-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "balkina",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/app_Icon.png",
    "splash": {
      "image": "./assets/splash_Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B7FC4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tseggaid.balkinaai",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app_Icon.png",
        "backgroundColor": "#6B7FC4"
      },
      "package": "com.tseggaid.balkinaai",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Balkina AI uses your location to find nearby businesses."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.tseggaid.balkinaai",
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "59418430-c484-4e9a-aedf-d4b254dc3dcb"
      }
    }
  }
}
